{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "remote-main",
  "description": "Allow music.youtube.com running in the main window to emit Tauri events",
  "windows": ["main"],
  "remote": {
    "urls": ["https://music.youtube.com/*"]
  },
  "permissions": [
    "core:default"
  ]
}
