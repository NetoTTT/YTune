{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ytune",
  "version": "0.2.0",
  "identifier": "com.foque.ytune",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "RWT5miEuQqmnp2qphWhXcLaAtgD772Dh9RzXHxMcLnKVDQ8eQ1PKRMiz",
      "endpoints": [
        "https://github.com/NetoTTT/YTune/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["ytune"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1 | libappindicator3-1", "libwebkit2gtk-4.1-0"]
      }
    }
  }
}
